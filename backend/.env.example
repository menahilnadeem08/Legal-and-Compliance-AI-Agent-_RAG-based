PORT=
DATABASE_URL=

# Email (required for OTP: admin signup, forgot password, employee temp password)
# Option 1 – Gmail (use an App Password, not your normal password):
# GMAIL_USER=your@gmail.com
# GMAIL_PASSWORD=your-app-password
# Option 2 – Custom SMTP:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASSWORD=your-password
# SMTP_SECURE=false

# Supabase (optional – for document file storage)
# If set, uploaded files are stored in Supabase Storage instead of local disk.
# Create a bucket named "documents" in your Supabase project (Storage → New bucket, private).
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

OPENAI_API_KEY=
EASYOCR_URL=http://localhost:8001
OCR_MIN_TEXT_LENGTH=50
OCR_CONFIDENCE_THRESHOLD=0.3
IMAGE_MAX_WIDTH=2000
CONTRAST_ENHANCE=1.8
OCR_MAX_FILE_SIZE=20971520  # 20MB